#optimal approch T.C O(nlogn) S.C O(n)
intervals = [[1,3],[2,6],[8,10],[15,18]]

# Step 1: sort based on first element
intervals.sort()

ans = []

for interval in intervals:

    # if ans is empty
    # OR no overlapping
    if not ans or interval[0] > ans[-1][1]:
        ans.append(interval)

    else:
        # merge intervals
        ans[-1][1] = max(ans[-1][1], interval[1])

print(ans)  
