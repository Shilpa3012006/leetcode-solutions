class Solution:
    def longestCommonPrefix(self, strs: List[str]) -> str:
        mini = len(strs[0])

        for word in strs:
            mini = min(mini, len(word))

        ans = ""

        for i in range(mini):

            for j in range(1, len(strs)):

                if strs[j][i] != strs[0][i]:
                    return ans

            ans += strs[0][i]

        return ans
        
