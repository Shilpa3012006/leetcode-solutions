#optimal approch T.C O(3n) S.C O(1)

nums=list(map(int,input().split()))
n=len(nums)
for i in range(n-2,-1,-1):
    if nums[i]<nums[i+1]:
        for j in range(n-1,i,-1):
            if nums[j]>nums[i]:
                nums[j],nums[i]=nums[i],nums[j]
                break
        nums[i+1:]=reversed(nums[i+1:])
        break
else:    
    nums.reverse()
print(nums)
