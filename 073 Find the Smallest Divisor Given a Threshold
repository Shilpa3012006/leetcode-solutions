class Solution:
    def smallestDivisor(self, nums: List[int], threshold: int) -> int:
        low = 1
        high = max(nums)
        ans= high

        while low <= high:
            mid = (low + high) // 2

            sum_div = 0
            for num in nums:
                sum_div += (num+mid-1)//mid

            if sum_div <= threshold:
                ans = mid
                high = mid - 1
            else:
                low = mid + 1

        return ans

                
