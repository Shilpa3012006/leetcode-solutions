#optimal approch T.C O(n) S.C O(n)
nums=list(map(int,input().split()))
n=len(nums)
ans=[0]*n
i=0
j=1
for num in nums:
    if num>0:
        ans[i]=num
        i+=2
    else:
        ans[j]=num
        j+=2
print(ans)


